# SENSUM Pipeline — environment variables
# Copy this file to `.env` (same directory) and fill in your keys.
# `.env` is gitignored. Never commit real keys.

# -----------------------------------------------------------------------------
# Required for every agent that calls Claude (Agents 3a, 3b, 4b, 5, 8, 10).
# Get a key at https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Required for every agent that calls Vertex AI / Gemini (Agents 0, 1, 2, 9, 9b, 10, 11).
# Project ID + location for Vertex AI; default location matches CLAUDE.md.
# Authenticate locally with: gcloud auth application-default login
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# Optional — Agent 11 (weekly niche intelligence) only.
# YouTube Data API v3 key + the channel ID Agent 11 reports against.
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
SENSUM_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Optional — Agent 1 (research) PubMed enrichment.
# Without it PubMed calls still work but at a lower rate limit.
# Get a key at https://www.ncbi.nlm.nih.gov/account/
# -----------------------------------------------------------------------------
NCBI_API_KEY=
